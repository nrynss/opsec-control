# Ignore for Docker build context (speeds up multi-stage build for P8)
.git
.gitignore
node_modules/
web/node_modules/
*.exe
bin/
eoc.exe
*.log
coverage.out
dist/
# Keep web/dist for reference, but Dockerfile rebuilds it
# .env*
*.md
reviews/
obsolete/
# Keep secrets out of build layers (the COPY . . go-build stage)
.env
.env.*
