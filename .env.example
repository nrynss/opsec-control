# Example environment for local / container runs (P8, hosting.md)
# Copy to .env and fill in values. The server reads these directly.

# Server
PORT=8080
WEB_DIR=web/dist

# Cerebras (required for live LLM / vision inference)
CEREBRAS_API_KEY=sk-your-cerebras-key-here
CEREBRAS_MODEL=gemma-4-31b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# OpenRouter (P9 — alternative provider, OpenAI-compatible endpoint)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=google/gemma-4-31b-it
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Provider selection (P9–P12):
#  - Boots on Cerebras by default; falls back to OpenRouter only if
#    CEREBRAS_API_KEY is unset AND OPENROUTER_API_KEY is set.
#  - With neither key set (or LLM_MOCK=true) the server runs in mock mode.
#  - Switch live at runtime via POST /provider {"provider":"openrouter"} — see hosting.md §4.1.
# LLM_MOCK=true

# Optional: speed etc. passed to cmd/eoc
# SIM_SPEED=4.0
